{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "TaskCompleted": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun .agents/hooks/check-write.ts"
          },
          {
            "type": "command",
            "command": "bun .agents/hooks/type-check.ts"
          },
          {
            "type": "command",
            "command": "bun .agents/hooks/test.ts"
          },
          {
            "type": "command",
            "command": "bun .agents/hooks/build.ts"
          }
        ]
      }
    ]
  },
  "enabledMcpjsonServers": [
    "playwright",
    "shadcn",
    "next-devtools"
  ],
  "permissions": {
    "allow": [
      "Bash(bun run check-write:*)",
      "Bash(bun run type-check:*)",
      "Bash(bun run test:*)",
      "Bash(bun run build:*)",
      "WebFetch(domain:ui.shadcn.com)"
    ]
  }
}
