{
  "name": "catalyst",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.20.0",
    "bun": ">=1.3.0"
  },
  "scripts": {
    "dev": "next dev",
    "scan": "REACT_SCAN=true next dev",
    "dev-email": "email dev --port 3001",
    "analyze": "ANALYZE=true next build --webpack",
    "build": "next build",
    "build:standalone": "EXPORT_MODE=standalone next build",
    "start": "next start",
    "type-check": "tsc --noEmit",
    "test": "bun test",
    "lint-staged": "lint-staged",
    "format": "biome format",
    "format-write": "biome format --write",
    "lint": "biome lint",
    "lint-write": "biome lint --write",
    "check": "biome check",
    "check-write": "biome check --write",
    "update:patch": "ncu -u --target patch -p bun && bun i",
    "update:minor": "ncu -u --target minor -p bun && bun i",
    "configure": "bun scripts/configure.ts",
    "prepare": "husky",
    "postinstall": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "bun run check"
    ]
  },
  "dependencies": {
    "@aws-sdk/client-ses": "3.1009.0",
    "@hookform/resolvers": "5.2.2",
    "@marsidev/react-turnstile": "1.4.2",
    "@microsoft/clarity": "1.0.2",
    "@next/third-parties": "16.2.4",
    "@prisma/adapter-pg": "7.8.0",
    "@prisma/client": "7.8.0",
    "@react-email/components": "1.0.9",
    "@tanstack/query-async-storage-persister": "5.100.6",
    "@tanstack/query-sync-storage-persister": "5.100.6",
    "@tanstack/react-query": "5.100.6",
    "@tanstack/react-query-persist-client": "5.100.6",
    "@trpc/client": "11.17.0",
    "@trpc/react-query": "11.17.0",
    "@trpc/server": "11.17.0",
    "@trpc/tanstack-react-query": "11.17.0",
    "better-auth": "1.5.5",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "idb-keyval": "6.2.2",
    "ioredis": "5.10.0",
    "javascript-time-ago": "2.6.4",
    "lucide-react": "1.12.0",
    "motion": "12.38.0",
    "next": "16.2.4",
    "next-themes": "0.4.6",
    "radix-ui": "1.4.3",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-hook-form": "7.71.2",
    "server-only": "0.0.1",
    "sonner": "2.0.7",
    "stripe": "20.0.0",
    "superjson": "2.2.6",
    "tailwind-merge": "3.5.0",
    "tw-animate-css": "1.4.0",
    "winston": "3.19.0",
    "winston-transport": "4.9.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.7",
    "@commitlint/cli": "20.4.4",
    "@commitlint/config-conventional": "20.4.4",
    "@next/bundle-analyzer": "16.2.4",
    "@opencode-ai/plugin": "1.2.26",
    "@react-email/preview-server": "5.2.9",
    "@tailwindcss/postcss": "4.2.4",
    "@types/bun": "1.3.10",
    "@types/node": "25.5.0",
    "@types/prompts": "2.4.9",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "commander": "14.0.3",
    "dotenv": "17.3.1",
    "dotenv-expand": "12.0.3",
    "husky": "9.1.7",
    "lint-staged": "16.4.0",
    "npm-check-updates": "19.6.3",
    "postcss": "8.5.12",
    "prisma": "7.8.0",
    "prompts": "2.4.2",
    "react-email": "5.2.9",
    "shadcn": "4.6.0",
    "tailwindcss": "4.2.4",
    "typescript": "5.9.3"
  },
  "overrides": {
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3"
  }
}
