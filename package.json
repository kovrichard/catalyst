{
  "name": "catalyst",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "24.15.0",
    "bun": "1.3.13"
  },
  "packageManager": "bun@1.3.14",
  "scripts": {
    "dev": "next dev",
    "scan": "REACT_SCAN=true next dev",
    "dev:email": "email dev --port 3001",
    "analyze": "ANALYZE=true next build --webpack",
    "build": "next build",
    "build:standalone": "EXPORT_MODE=standalone next build",
    "start": "next start",
    "type-check": "tsc --noEmit",
    "test": "bun test",
    "lint-staged": "lint-staged",
    "format": "biome format",
    "format-write": "biome format --write",
    "lint": "biome lint",
    "lint-write": "biome lint --write",
    "check": "biome check",
    "check-write": "biome check --write",
    "knip": "knip",
    "jscpd": "jscpd --no-tips",
    "klint": "klint",
    "madge": "madge --circular --extensions ts,tsx --ts-config tsconfig.json --exclude 'prisma/generated' src",
    "lf": "bun .agents/scripts/check-lf.ts",
    "secretlint": "secretlint \"**/*\"",
    "update:patch": "ncu -u --target patch -p bun && bun i",
    "update:minor": "ncu -u --target minor -p bun && bun i",
    "configure": "bun scripts/configure.ts",
    "prepare": "husky",
    "postinstall": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "bun run check"
    ]
  },
  "dependencies": {
    "@aws-sdk/client-ses": "3.1079.0",
    "@hookform/resolvers": "5.4.0",
    "@marsidev/react-turnstile": "1.5.3",
    "@microsoft/clarity": "1.0.2",
    "@prisma/adapter-pg": "7.8.0",
    "@prisma/client": "7.8.0",
    "@react-email/components": "1.0.12",
    "@tanstack/react-query": "5.101.2",
    "@tanstack/react-query-persist-client": "5.101.2",
    "@trpc/client": "11.18.0",
    "@trpc/server": "11.18.0",
    "@trpc/tanstack-react-query": "11.18.0",
    "better-auth": "1.6.23",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "idb-keyval": "6.2.6",
    "ioredis": "5.11.1",
    "javascript-time-ago": "2.6.4",
    "lucide-react": "1.23.0",
    "next": "16.2.10",
    "next-themes": "0.4.6",
    "radix-ui": "1.6.1",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-hook-form": "7.80.0",
    "server-only": "0.0.1",
    "sonner": "2.0.7",
    "stripe": "22.3.0",
    "superjson": "2.2.6",
    "tailwind-merge": "3.6.0",
    "tw-animate-css": "1.4.0",
    "winston": "3.19.0",
    "winston-transport": "4.9.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.2",
    "@commitlint/cli": "21.2.0",
    "@commitlint/config-conventional": "21.2.0",
    "@konvert7/klint": "0.26.0",
    "@next/bundle-analyzer": "16.2.10",
    "@opencode-ai/plugin": "1.17.13",
    "@react-email/ui": "6.6.6",
    "@secretlint/secretlint-rule-preset-recommend": "13.0.2",
    "@tailwindcss/postcss": "4.3.2",
    "@types/bun": "1.3.14",
    "@types/node": "26.1.0",
    "@types/prompts": "2.4.9",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "babel-plugin-react-compiler": "1.0.0",
    "commander": "15.0.0",
    "dotenv": "17.4.2",
    "dotenv-expand": "13.0.0",
    "husky": "9.1.7",
    "jscpd": "5.0.11",
    "knip": "6.24.0",
    "lint-staged": "17.0.8",
    "madge": "8.0.0",
    "npm-check-updates": "22.2.9",
    "postcss": "8.5.16",
    "postcss-load-config": "6.0.1",
    "prisma": "7.8.0",
    "prompts": "2.4.2",
    "react-email": "6.6.6",
    "secretlint": "13.0.2",
    "shadcn": "4.13.0",
    "tailwindcss": "4.3.2",
    "typescript": "6.0.3"
  },
  "overrides": {
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3"
  }
}
